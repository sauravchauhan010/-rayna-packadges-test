rules_version = '2';

// ─── HOW TO APPLY THESE ──────────────────────────────────────────────────
// Firebase Console → your project → Firestore Database → Rules tab →
// paste this in → Publish. (This file isn't auto-deployed by Vercel; it's
// a copy of what should be live in the console, kept here for review.)
//
// Why this matters even though the API routes now do the real gating:
// the Admin SDK (used by api/*.js) always bypasses these rules — it
// authenticates with a service account, not as a Firestore "user". These
// rules are what stop someone who has your public Firebase config from
// talking to Firestore *directly*, skipping your API routes entirely.

service cloud.firestore {
  match /databases/{database}/documents {

    match /artifacts/{appId}/public/data/{document=**} {

      // Packages are public marketing content (tour packages customers
      // browse) — safe to read directly from the client.
      //
      // NOTE: writes are still left open here on purpose. Unlike agents/
      // logs, package add/edit/delete in this codebase still goes through
      // the client Firestore SDK directly (js/db-packages.js), gated only
      // by the admin UI's login state — not yet migrated to a server API
      // route the way agents/logs/login were in this pass. Setting
      // `allow write: if false` here would break the admin's ability to
      // publish packages entirely. This is a known follow-up: move
      // package writes behind an admin-gated /api/packages route (same
      // pattern as /api/agents), then tighten this to `if false` too.
      match /packages/{packageId} {
        allow read: if true;
        allow write: if true; // TODO: tighten once packages CRUD moves to a server route
      }

      // Agents and login logs must NEVER be reachable directly from the
      // client — they only go through /api/agents, /api/agent-login, and
      // /api/agent-logs (Admin SDK, bypasses these rules entirely).
      match /agents/{agentId} {
        allow read, write: if false;
      }

      match /agent_login_logs/{logId} {
        allow read, write: if false;
      }
    }
  }
}
